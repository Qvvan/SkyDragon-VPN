# =================================
# Настройки базы данных PostgreSQL
# =================================
POSTGRES_VERSION=16.2
POSTGRES_HOST=b2b_db
POSTGRES_DATABASE=b2b_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# =================================
# Настройки приложения
# =================================
APP_NAME=Кластеры ДМС
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8001
APP_SECRET_KEY=asdasd
# JWT для сайта (HS256, тот же секрет что APP_SECRET_KEY)
APP_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Секрет вызова internal API из бота (заголовок X-Bot-Secret)
APP_BOT_API_SECRET=

# =================================
# Логирование
# =================================
LOG_LEVEL=INFO
LOG_JSON_FORMAT=true
LOG_FILE=/app/logs/app.log


# =================================
# SSMS — авторизация входящим звонком (wait_call)
# =================================
SSMS_EMAIL=your_login@example.com
SSMS_PASSWORD=your_password
# Либо используйте API key (тогда EMAIL и PASSWORD не нужны):
# SSMS_API_KEY=your_api_key
# Секрет вебхука: добавляется к URL хука и проверяется при получении.
# Сгенерируйте: python -c "import secrets; print(secrets.token_urlsafe(32))"
SSMS_WEBHOOK_SECRET=change-me-in-production

