# Скопируйте в .env.staging:  copy .env.staging.example .env.staging
# Запуск: docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
#
# Сайт: https://test.skydragonbot.ru (nginx :443, сертификаты с хоста /etc/letsencrypt)

BOT_TOKEN=
TELEGRAM_PROXY=

DB_HOST=db
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DSN=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

ADMIN_IDS=
CRYPTO_KEY=

ERROR_GROUP_ID=
INFO_GROUP_ID=

MY_SECRET_URL=mysecreturl
LOGIN_X_UI_PANEL=admin
PASSWORD_X_UI_PANEL=admin
PORT_X_UI=54321

SHOP_ID=
SHOP_API_TOKEN=

INN=
PASSWORD_MY_NALOG=
SOURCE_DEVICE_ID=

# Обязательно HTTPS без порта (стандартный 443)
PUBLIC_BASE_URL=https://test.skydragonbot.ru
TELEGRAM_BOT_URL=https://t.me/SkyDragonVPNBot
TELEGRAM_SUPPORT_URL=https://t.me/SkyDragonSupport
TELEGRAM_SUPPORT_USERNAME=SkyDragonSupport
TELEGRAM_YOOKASSA_RETURN_URL=

# Postgres наружу (опционально); nginx слушает 80+443 на хосте
STAGING_API_PORT=12346
STAGING_DB_PORT=5443
