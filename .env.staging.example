# Скопируйте в .env.staging — не коммитьте с реальными секретами.
# docker compose -f docker-compose.staging.yml --env-file .env.staging up -d
#
# Как на проде: DB_HOST=telegram-db и DSN с ${...} — compose подставляет переменные
# при старте контейнеров. В staging у Postgres в сети задан алиас telegram-db
# (см. docker-compose.staging.yml), чтобы имя хоста совпадало с продом.

BOT_TOKEN=
TELEGRAM_PROXY=

DB_HOST=telegram-db
DB_PORT=5432
DB_NAME=vpn_bot_tg
DB_USER=vpn_bot_tg
DB_PASSWORD=
DSN=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

ADMIN_IDS=
CRYPTO_KEY=

ERROR_GROUP_ID=
INFO_GROUP_ID=
ONLINE_ABUSE_CHAT_ID=0

MY_SECRET_URL=mysecreturl
LOGIN_X_UI_PANEL=admin
PASSWORD_X_UI_PANEL=admin
PORT_X_UI=54321

SHOP_ID=
SHOP_API_TOKEN=

INN=
PASSWORD_MY_NALOG=
SOURCE_DEVICE_ID=

PUBLIC_BASE_URL=https://test.skydragonbot.ru
TELEGRAM_BOT_URL=https://t.me/SkyDragonVPNBot
TELEGRAM_SUPPORT_URL=https://t.me/SkyDragonSupport
TELEGRAM_SUPPORT_USERNAME=SkyDragonSupport
TELEGRAM_YOOKASSA_RETURN_URL=

STAGING_API_PORT=12346
STAGING_DB_PORT=5443
